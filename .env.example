# Launch fees (all optional; unset means every launch is free)
# Flat fee in lamports charged inside the atomic launch transaction (100000000 = 0.1 SOL)
LAUNCH_FEE_LAMPORTS=
# Treasury wallet receiving SOL fees; unset disables the SOL payment path
LAUNCH_FEE_TREASURY=
# Raw LCKD base units (6 decimals) held to waive the fee entirely (250000000000 = 250k LCKD)
LAUNCH_FEE_WAIVER_LCKD_RAW=
# Discount in basis points for paying by burning LCKD instead of SOL (2000 = 20%)
LAUNCH_FEE_BURN_DISCOUNT_BPS=
