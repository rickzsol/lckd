NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=
ALLOWED_ORIGIN=
HELIUS_RPC_URL=
NEXT_PUBLIC_HELIUS_RPC_URL=
NEXT_PUBLIC_STREAMFLOW_CLUSTER=mainnet
STREAMFLOW_PROGRAM_ID=
PINATA_JWT=
PINATA_GATEWAY=
GITHUB_PAT=
CRON_SECRET=
ROBINHOOD_RPC_URL=https://rpc.mainnet.chain.robinhood.com
NEXT_PUBLIC_ENABLE_ROBINHOOD_LAUNCHES=false
# SAS attestations (default off). Cluster is devnet or mainnet.
SAS_ENABLED=false
SAS_CLUSTER=devnet
# Cluster-specific RPC. SAS_CLUSTER selects which one is used; the RPC genesis
# hash is verified against the cluster before any signing. Never share one URL
# across clusters. HELIUS_RPC_URL is only a legacy fallback for the active cluster.
SAS_MAINNET_RPC_URL=
SAS_DEVNET_RPC_URL=
# Pinned PDAs published for third-party verification (base58).
SAS_CREDENTIAL_PDA=
SAS_SCHEMA_PDA=
# Hot authorized-signer secret (base58 or JSON 64-byte array). Prefer a KMS/remote signer in prod.
SAS_SIGNER_SECRET=
# Separate fee payer secret funding rent and network fees.
SAS_FEE_PAYER_SECRET=
